
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model user {
  id               Int            @id @default(autoincrement())
  name             String
  cpf              String         @unique(map: "User_cpf_key")
  email            String         @unique(map: "User_email_key")
  passwordHash     String
  expoPushToken    String?        @db.VarChar(255)
  cep              String?
  address          String?
  plate            String?
  primeiroLogin    Boolean        @default(false)
  latitude         Float?
  longitude        Float?
  profilePhotoUrl  String?
  isActive         Boolean        @default(true)
  acceptsMarketingNotifications Boolean @default(false)
  notificacaoIgnicao Boolean @default(true)
  ancoraAtiva      Boolean        @default(false)
  role             UserRole       @default(USER)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  notifications    Notification[]
  userVehicles     UserVehicle[]
}

model ReinspectionAnalyst {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(150) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserVehicle {
  id                 Int      @id @default(autoincrement())
  userId             Int
  chassi             String   @db.VarChar(100)
  plate              String?  @db.VarChar(20)
  externalVehicleCode String? @db.VarChar(50)
  isActive           Boolean  @default(true)
  reinspectionRequired Boolean @default(false)
  lastSyncAt         DateTime @default(now())
  user               user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reinspections      Reinspection[]

  @@unique([userId, chassi], map: "UserVehicle_userId_chassi_key")
  @@index([chassi], map: "UserVehicle_chassi_idx")
  @@index([userId], map: "UserVehicle_userId_idx")
}

model VehicleWebhookEvent {
  id          Int      @id @default(autoincrement())
  chassi      String   @db.VarChar(100)
  evento      String?  @db.VarChar(255)
  tipoevento  Int?
  provider    String   @default("M7") @db.VarChar(32)
  payload     Json
  receivedAt  DateTime @default(now())
  processed   Boolean  @default(false)

  @@index([chassi], map: "VehicleWebhookEvent_chassi_idx")
  @@index([tipoevento], map: "VehicleWebhookEvent_tipoevento_idx")
  @@index([receivedAt], map: "VehicleWebhookEvent_receivedAt_idx")
}


model SliderInfo {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  description String   @db.Text
  imageUrl    String   @db.VarChar(500)
  whatsapp    String?  @db.VarChar(50)
  linkUrl     String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

//
// ======================================================
// NOVO MODEL — WORKSHOP (OFICINA)
// ======================================================
//

model workshop {
  id                Int       @id @default(autoincrement())

  // Dados principais
  name              String    @db.VarChar(150)
  email             String?   @db.VarChar(150)
  shortDescription  String   @db.VarChar(100)
  phone             String
  phoneSecondary    String?
  whatsapp          String?
  description       String   @db.VarChar(400)
  services          Json?
  specialty         WorkshopSpecialty @default(CARRO)

  // Flags
  isActive          Boolean   @default(true)
  featuredInApp     Boolean   @default(false)

  // Coordenadas
  latitude          Float?
  longitude         Float?

  // Endereço
  cep               String
  address           String
  district          String     // bairro
  number            String
  complement        String?
  city              String
  state             State
  mapFrameUrl       String?     // iframe embed

  // Fotos
  photoFrontUrl     String?
  photoBackUrl      String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

enum State {
  AC
  AL
  AP
  AM
  BA
  CE
  DF
  ES
  GO
  MA
  MT
  MS
  MG
  PA
  PB
  PR
  PE
  PI
  RJ
  RN
  RS
  RO
  RR
  SC
  SP
  SE
  TO
}

enum WorkshopSpecialty {
  CARRO
  MOTO
}

// ======================================================
// NOVO MODEL — DOCUMENTS
// ======================================================

model Document {
  id                Int           @id @default(autoincrement())

  description       String        @db.VarChar(255)   // descrição do documento
  documentUrl       String        @db.VarChar(500)   // link do documento (PDF, imagem, etc.)
  type              DocumentType  // tipo do documento

  // Flags de visibilidade
  visibleConsultor  Boolean       @default(false)    // visível no app do consultor
  visibleAssociado  Boolean       @default(false)    // visível no app do associado
  visibleBoth       Boolean       @default(false)    // visível em ambos

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum DocumentType {
  TERMO_EVENTO
  TERMO_PAYMENTS
  TERMO_REVISTORIA
  TERMO_USO_REGULAMENTO
}

// ======================================================
// NOVO MODEL — NOTIFICATIONS
// ======================================================

// ======================================================
// NOVO MODEL — REVISTORIA
// ======================================================

enum ReinspectionVehicleType {
  VEICULOS_LEVES
  MOTOS
  CAMINHOES
}

enum ReinspectionStatus {
  PENDENTE
  EM_ANALISE
  FINALIZADA
}

model Reinspection {
  id              Int                     @id @default(autoincrement())
  userVehicleId   Int
  vehicleType     ReinspectionVehicleType
  status          ReinspectionStatus      @default(PENDENTE)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  userVehicle     UserVehicle             @relation(fields: [userVehicleId], references: [id], onDelete: Cascade)
  photos          ReinspectionPhoto[]

  @@index([userVehicleId], map: "Reinspection_userVehicleId_idx")
  @@index([status], map: "Reinspection_status_idx")
}

model ReinspectionPhoto {
  id              Int          @id @default(autoincrement())
  reinspectionId  Int
  nomeArquivo     String       @db.VarChar(255)
  codigoTipo      Int?
  url             String?      @db.VarChar(500)
  hinovaSituacao  String?      @db.VarChar(50)   // retorno da Hinova: "Inserido", erro, etc.
  sentToHinova    Boolean      @default(false)   // controle de envio
  createdAt       DateTime     @default(now())

  reinspection    Reinspection @relation(fields: [reinspectionId], references: [id], onDelete: Cascade)

  @@index([reinspectionId], map: "ReinspectionPhoto_reinspectionId_idx")
}

// ======================================================
// NOVO MODEL — TEMPLATE DE REVISTORIA
// ======================================================

model ReinspectionTemplatePhoto {
  id           Int                     @id @default(autoincrement())
  vehicleType  ReinspectionVehicleType
  photoUrl     String                  @db.VarChar(500)
  ordem        Int

  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([vehicleType, ordem], map: "ReinspectionTemplatePhoto_vehicleType_ordem_key")
  @@index([vehicleType], map: "ReinspectionTemplatePhoto_vehicleType_idx")
}

model Notification {
  id              Int       @id @default(autoincrement())
  userId          Int
  expoPushToken   String    @db.VarChar(255)
  title           String    @db.VarChar(255)
  body            String    @db.Text
  data            Json      // { plate: string, ignition: 'on' | 'off', ... }
  read            Boolean   @default(false)
  sentAt          DateTime  @default(now())
  readAt          DateTime? 
  deleted         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relação com user
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Índices para performance
  @@index([userId, read], map: "Notification_userId_read_idx")
  @@index([sentAt], map: "Notification_sentAt_idx")
  @@index([createdAt], map: "Notification_createdAt_idx")
}
